---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_AUTHOR, SITE_REPOSITORY_URL, SITE_TITLE } from '../consts';
---

<SiteLayout title={`关于 | ${SITE_TITLE}`} description="站点说明、内容范围以及需要替换的个人信息。">
	<section class="page-intro panel">
		<p class="eyebrow">About</p>
		<h1>关于这个博客</h1>
		<p>
			这不是一段虚构的个人简介，而是一份已经接好功能的博客骨架。你可以把这里改成
			{SITE_AUTHOR}
			的真实介绍，也可以直接重写成自己的作品集或长期笔记页。
		</p>
	</section>

	<section class="content-grid">
		<div class="panel">
			<h2>默认已经配置好的内容</h2>
			<ul>
				<li>Markdown / MDX 写作</li>
				<li>RSS 与 sitemap</li>
				<li>标签归档页</li>
				<li>适合 Cloudflare Pages 的静态构建</li>
			</ul>
		</div>
		<div class="panel">
			<h2>优先替换的地方</h2>
			<ul>
				<li><code>src/consts.ts</code>：站点标题、作者、仓库地址</li>
				<li><code>src/content/blog/</code>：文章 frontmatter 和正文</li>
				<li><code>src/pages/about.astro</code>：真实个人介绍</li>
			</ul>
		</div>
	</section>

	<section class="panel">
		<h2>推荐的写作范围</h2>
		<p>
			个人博客不需要把所有内容都写成教程。更值得长期积累的通常是：项目复盘、工具链配置、
			系统运维经验、读书和思考记录，以及你愿意持续更新的主题。
		</p>
		<p>
			如果你准备公开这个仓库，当前默认地址会指向
			<a href={SITE_REPOSITORY_URL} target="_blank">GitHub 仓库</a>。后续如果你改了仓库名，记得一起更新。
		</p>
	</section>
</SiteLayout>

<style>
	.page-intro,
	.content-grid,
	.panel:last-child {
		margin-bottom: 1.25rem;
	}
	.page-intro {
		padding: clamp(1.25rem, 3vw, 2rem);
	}
	.page-intro p:last-of-type {
		max-width: 42rem;
		color: rgb(var(--muted));
	}
	.content-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	.content-grid .panel,
	.panel:last-child {
		padding: clamp(1.25rem, 3vw, 2rem);
	}
	.content-grid ul {
		padding-left: 1.2rem;
	}
	@media (max-width: 820px) {
		.content-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
