---
import PostCard from '../../components/PostCard.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { SITE_TITLE } from '../../consts';
import { getAllTags, getPublishedPosts } from '../../utils/blog';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<SiteLayout title={`文章 | ${SITE_TITLE}`} description="所有已发布的博客文章。">
	<section class="page-intro panel">
		<p class="eyebrow">Archive</p>
		<h1>全部文章</h1>
		<p>
			这里收录了已经发布的所有内容。当前共有 {posts.length} 篇文章，覆盖 {tags.length} 个标签。
		</p>
		<a class="button secondary" href="/tags/">按标签浏览</a>
	</section>

	<div class="post-grid">
		{posts.map((post, index) => <PostCard post={post} featured={index === 0} />)}
	</div>
</SiteLayout>

<style>
	.page-intro {
		padding: clamp(1.25rem, 3vw, 2rem);
		margin-bottom: 1.5rem;
	}
	.page-intro p:last-of-type {
		max-width: 38rem;
		color: rgb(var(--muted));
	}
</style>
