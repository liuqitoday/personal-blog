---
import PostCard from '../../components/PostCard.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { SITE_TITLE } from '../../consts';
import { getAllTags, getPostsByTag, getPublishedPosts } from '../../utils/blog';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const tags = getAllTags(posts);

	return tags.map((item) => ({
		params: { tag: item.slug },
		props: item,
	}));
}

const posts = await getPublishedPosts();
const { tag, slug, count } = Astro.props;
const taggedPosts = getPostsByTag(posts, slug);
---

<SiteLayout title={`${tag} | ${SITE_TITLE}`} description={`查看标签 ${tag} 下的所有文章。`}>
	<section class="page-intro panel">
		<p class="eyebrow">Tag</p>
		<h1>#{tag}</h1>
		<p>这个标签下目前有 {count} 篇文章。</p>
		<a class="button secondary" href="/tags/">返回全部标签</a>
	</section>

	<div class="post-grid">
		{taggedPosts.map((post, index) => <PostCard post={post} featured={index === 0} />)}
	</div>
</SiteLayout>

<style>
	.page-intro {
		padding: clamp(1.25rem, 3vw, 2rem);
		margin-bottom: 1.25rem;
	}
	.page-intro p:last-of-type {
		color: rgb(var(--muted));
	}
</style>
