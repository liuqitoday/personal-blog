---
import PostCard from '../components/PostCard.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import {
	SITE_DESCRIPTION,
	SITE_INTRO,
	SITE_TAGLINE,
	SITE_TITLE,
	TECH_STACK,
} from '../consts';
import { getAllTags, getPublishedPosts } from '../utils/blog';

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 3);
const tags = getAllTags(posts);
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero panel">
		<p class="eyebrow">软件开发 · 工具 · 网络 · AI</p>
		<h1>{SITE_TAGLINE}</h1>
		<p class="lead">{SITE_INTRO}</p>
		<div class="actions">
			<a class="button" href="/blog/">开始读文章</a>
			<a class="button secondary" href="/about/">关于我</a>
		</div>
		<ul class="stack-list">
			{TECH_STACK.map((item) => <li>{item}</li>)}
		</ul>
	</section>

	<section class="stats-grid">
		<div class="stat-card panel">
			<span class="stat-value">{posts.length}</span>
			<span class="stat-label">已发布文章</span>
		</div>
		<div class="stat-card panel">
			<span class="stat-value">{tags.length}</span>
			<span class="stat-label">可用标签</span>
		</div>
		<div class="stat-card panel">
			<span class="stat-value">RSS</span>
			<span class="stat-label">订阅与分发已开启</span>
		</div>
	</section>

	<section class="section-head">
		<div>
			<p class="eyebrow">Latest</p>
			<h2 class="section-title">最近发布</h2>
		</div>
		<a class="section-link" href="/blog/">查看全部文章</a>
	</section>

	<div class="post-grid">
		{latestPosts.map((post, index) => <PostCard post={post} featured={index === 0} />)}
	</div>

	<section class="panel checklist">
		<div>
			<p class="eyebrow">Topics</p>
			<h2 class="section-title">内容方向</h2>
		</div>
		<ol>
			<li>软件开发中的工程实践与项目复盘。</li>
			<li>高频工具、命令行和工作流优化技巧。</li>
			<li>家庭网络、OpenWrt 与 AI 应用实战教程。</li>
		</ol>
	</section>
</SiteLayout>

<style>
	.hero {
		padding: clamp(1.4rem, 4vw, 3rem);
	}
	.hero h1 {
		max-width: 12ch;
		margin-top: 0.35rem;
	}
	.lead {
		max-width: 44rem;
		margin: 1rem 0 0;
		font-size: 1.12rem;
		color: rgb(var(--muted));
	}
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-top: 1.75rem;
	}
	.stack-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 2rem 0 0;
		padding: 0;
		list-style: none;
	}
	.stack-list li {
		padding: 0.72rem 0.95rem;
		border-radius: 999px;
		background: rgba(var(--accent-soft-rgb), 0.28);
		color: rgb(var(--ink));
		font-weight: 700;
	}
	.stats-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin: 1.25rem 0 2.5rem;
	}
	.stat-card {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		padding: 1.4rem;
	}
	.stat-value {
		font-size: 1.9rem;
		font-weight: 800;
		color: rgb(var(--ink));
	}
	.stat-label {
		color: rgb(var(--muted));
	}
	.section-head {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}
	.section-link {
		font-weight: 700;
		text-decoration: none;
	}
	.checklist {
		margin-top: 2rem;
		padding: clamp(1.3rem, 3vw, 2rem);
	}
	.checklist ol {
		margin: 1rem 0 0;
		padding-left: 1.15rem;
		color: rgb(var(--muted));
	}
	.checklist li + li {
		margin-top: 0.75rem;
	}
	@media (max-width: 820px) {
		.stats-grid {
			grid-template-columns: 1fr;
		}
		.section-head {
			align-items: start;
			flex-direction: column;
		}
	}
</style>
