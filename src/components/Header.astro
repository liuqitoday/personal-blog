---
import { EXTERNAL_LINKS, NAV_LINKS, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav class="site-nav">
		<a class="brand" href="/">
			<span class="brand-mark">LQ</span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			{
				NAV_LINKS.map((link) => (
					<HeaderLink href={link.href}>{link.label}</HeaderLink>
				))
			}
		</div>
		<div class="external-links">
			{
				EXTERNAL_LINKS.map((link) => (
					<a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined}>
						{link.label}
					</a>
				))
			}
		</div>
	</nav>
</header>
<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		padding: 1rem;
		backdrop-filter: blur(18px);
		background: rgba(var(--paper), 0.72);
		border-bottom: 1px solid rgba(var(--line), 0.72);
	}
	.site-nav {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		font-size: 1rem;
		font-weight: 800;
		letter-spacing: 0.03em;
		color: rgb(var(--ink));
		text-decoration: none;
	}
	.brand-mark {
		display: inline-grid;
		place-items: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 999px;
		background: rgb(var(--ink));
		color: rgb(var(--paper));
		font-size: 0.82rem;
	}
	.internal-links,
	.external-links {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}
	.external-links a {
		display: inline-flex;
		align-items: center;
		padding: 0.65rem 0.85rem;
		border-radius: 999px;
		color: rgb(var(--muted));
		font-size: 0.92rem;
		font-weight: 700;
		text-decoration: none;
		transition:
			background-color 180ms ease,
			color 180ms ease;
	}
	.external-links a:hover {
		background: rgba(var(--accent-soft-rgb), 0.26);
		color: rgb(var(--ink));
	}
	@media (max-width: 920px) {
		.site-nav {
			flex-wrap: wrap;
			justify-content: center;
		}
		.brand {
			width: 100%;
			justify-content: center;
		}
	}
	@media (max-width: 640px) {
		.external-links {
			display: none;
		}
		.internal-links {
			flex-wrap: wrap;
			justify-content: center;
		}
	}
</style>
